// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma" // or remove this to use the default
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntryType {
  INCOME
  EXPENSE
}

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  role String? // "ACCOUNTANT" or "CLIENT"

  accountantId String?
  accountant   User?   @relation("AccountantClients", fields: [accountantId], references: [id])
  clients      User[]  @relation("AccountantClients")

  invoices Invoice[]
  entries  BookkeepingEntry[]

  @@map("user")
}

model Invoice {
  id         String @id @default(cuid())
  fileUrl    String
  rawOcrData Json?

  vendorName    String?
  invoiceNumber String?
  invoiceDate   DateTime?
  dueDate       DateTime?
  totalAmount   Decimal?  @db.Decimal(10, 2)
  taxAmount     Decimal?  @db.Decimal(10, 2)
  currency      String    @default("USD")

  status String @default("PENDING") // PENDING, CONFIRMED, REJECTED

  userId String
  user   User   @relation(fields: [userId], references: [id])

  bookkeepingEntry BookkeepingEntry?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("invoice")
}

model BookkeepingEntry {
  id           String    @id @default(cuid())
  type         EntryType
  date         DateTime
  counterparty String
  total        Decimal   @db.Decimal(10, 2)
  tax          Decimal   @db.Decimal(10, 2)
  category     String?
  notes        String?

  invoiceId String?  @unique
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bookkeeping_entry")
}
